    {
      "parameters": {
        "jsCode": "// A lista de colunas a serem padronizadas\nconst colunasDeTexto = [\n  'building',\n  'category',\n  'costEstimateGroup',\n  'partner',\n  'paymentMethod',\n  'documentNumber',\n  'walletFormattedName'\n];\n\n// Itera sobre cada item no array de entrada 'items'\nfor (const item of items) {\n  // Acessa o objeto JSON dentro de cada item\n  const jsonItem = item.json;\n\n  // Itera sobre cada coluna de texto e a converte para maiúsculo\n  for (const key of colunasDeTexto) {\n    if (jsonItem[key] && typeof jsonItem[key] === 'string') {\n      jsonItem[key] = jsonItem[key].toUpperCase();\n    }\n  }\n}\n\n// Retorna o array de itens completo e modificado para o próximo nó\nreturn items;"
      },
