    {
      "parameters": {
        "jsCode": "// Array que irá armazenar nossa lista de períodos\nconst periodos = [];\n\n// Define as datas de início e fim da geração da lista\nconst dataInicial = new Date('2024-06-01T12:00:00');\nconst dataFinal = new Date('2026-12-31T12:00:00');\n\nlet dataCorrente = dataInicial;\n\n// Loop que avança mês a mês\nwhile (dataCorrente <= dataFinal) {\n  const ano = dataCorrente.getFullYear();\n  const mes = dataCorrente.getMonth(); // 0 = Janeiro, 11 = Dezembro\n\n  // Calcula o primeiro dia do mês\n  const primeiroDia = new Date(ano, mes, 1);\n  \n  // Calcula o último dia do mês (indo para o próximo mês e subtraindo um dia)\n  const ultimoDia = new Date(ano, mes + 1, 0);\n\n  // Formata as datas para o formato 'YYYY-MM-DD'\n  const data_inicio = primeiroDia.toISOString().split('T')[0];\n  const data_fim = ultimoDia.toISOString().split('T')[0];\n\n  // Adiciona o objeto com as datas à nossa lista\n  periodos.push({\n    data_inicio: data_inicio,\n    data_fim: data_fim\n  });\n\n  // Avança para o próximo mês\n  dataCorrente.setMonth(dataCorrente.getMonth() + 1);\n}\n\n// Retorna os dados no formato que o n8n espera para iterar\nreturn periodos.map(item => ({ json: item }));"
      },
