      "id": "5b0e3e68-2e54-4312-aece-08b9e467fe6f",
      "name": "Separar Fornecedores e Rateios"
    },
    {
      "parameters": {
        "jsCode": "// Este nó deve estar após o último Postgres (Buscando IDs Fornecedor)\n// Configure como \"Run Once for All Items\"\n\nconst items = $input.all();\n\nreturn items.map((item, i) => {\n    // 1. Puxa os dados que vieram do Pipefy (através do nó de separação/lógica inicial)\n    // Certifique-se de que o campo 'descricao' foi incluído no nó 'Separar Rateios para Select'\n    const pipefy = $('Separar Rateios para Select').itemMatching(i).json;\n\n    // 2. Puxa os IDs do Sienge encontrados nos 3 nós de Postgres\n    const dbObra = $('Selecionar ID CC e Obra').itemMatching(i).json;\n    const dbCat  = $('Buscando IDs Categoria').itemMatching(i).json;\n    const dbForn = $('Buscando IDs Fornecedor').itemMatching(i).json;\n\n    return {\n        json: {\n            // Informações do Pipefy (Dados originais e consolidados)\n            fornecedor_nome: pipefy.fornecedor_nome,\n            fornecedor_card_id: pipefy.fornecedor_card_id,\n            rateio_card_id: pipefy.rateio_card_id,\n            centro_de_custo_nome: pipefy.centro_de_custo,\n            valor_original: pipefy.valor,\n            categoria_nome_pipefy: pipefy.categoria,\n            // Adicionando a descrição aqui\n            descricao_rateio: pipefy.descricao, \n\n            // Informações da Obra e Centro de Custo (Postgres 1)\n            id_obra_sienge: dbObra.idobra,\n            nome_obra_sienge: dbObra.nomeobra,\n            id_cc_sienge: dbObra.idcc,\n            nome_cc_sienge: dbObra.nomecc,\n\n            // Informações da Categoria de Gasto (Postgres 2)\n            id_categoria_sienge: dbCat.idcategoria,\n            nome_categoria_sienge: dbCat.nomecategoria,\n\n            // Informações do Fornecedor no Sienge (Postgres 3)\n            id_fornecedor_sienge: dbForn.idfornecedor,\n            nome_fornecedor_sienge: dbForn.nomefornecedor\n        }\n    };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -128,
        1232
      ],
      "id": "5ca8de81-859b-4c79-a96c-7f0fe3aa980c",
      "name": "Juntando Infos"
    },
    {
      "parameters": {
        "jsCode": "// Este nó deve ser configurado como \"Run Once for All Items\"\nconst items = $input.all();\nconst grouped = {};\n\n// 1. Puxa a data global do nó de mapeamento inicial\nconst dataPai = $('Mapeando IDs Pai').item.json.data_de_vencimento_definitiva_1;\nconst partesData = dataPai.split(' ')[0].split('/');\nconst dueDateISO = `${partesData[2]}-${partesData[1]}-${partesData[0]}`;\n\nfor (const item of items) {\n    const data = item.json;\n    const key = data.fornecedor_card_id; // Chave única da NF\n\n    if (!grouped[key]) {\n        grouped[key] = {\n            id_fornecedor: data.id_fornecedor_sienge,\n            nome_fornecedor: data.nome_fornecedor_sienge,\n            id_categoria: data.id_categoria_sienge,\n            data_vencimento: dueDateISO,\n            valor_total_nf: 0,\n            descricao_consolidada: \"\", \n            rateios: [],\n            // Helper para evitar duplicatas de processamento\n            processedRateioIds: new Set() \n        };\n    }\n\n    // --- TRAVA DE DUPLICIDADE ---\n    // Se este ID de rateio já foi processado para esta NF, ignora o item atual\n    if (grouped[key].processedRateioIds.has(data.rateio_card_id)) {\n        continue;\n    }\n    // Marca como processado\n    grouped[key].processedRateioIds.add(data.rateio_card_id);\n    // ----------------------------\n\n    const valorFloat = parseFloat(data.valor_original.replace(/\\./g, '').replace(',', '.'));\n    grouped[key].valor_total_nf += valorFloat;\n\n    // Lógica de concatenação da descrição externa\n    const descAtual = data.descricao_rateio || \"Sem descrição\";\n    if (grouped[key].descricao_consolidada === \"\") {\n        grouped[key].descricao_consolidada = descAtual;\n    } else {\n        grouped[key].descricao_consolidada += ` // ${descAtual}`;\n    }\n\n    // Adiciona o rateio à lista\n    grouped[key].rateios.push({\n        id_cc_sienge: data.id_cc_sienge,\n        nome_cc_sienge: data.nome_cc_sienge,\n        id_obra_sienge: data.id_obra_sienge,\n        valor_rateado: valorFloat,\n        descricao: descAtual\n    });\n}\n\n// 2. Transforma o objeto agrupado em um array de itens para o n8n\nreturn Object.keys(grouped).map(key => {\n    // Remove o helper antes de enviar a saída\n    delete grouped[key].processedRateioIds;\n    return {\n        json: grouped[key]\n    };\n});"
      },
