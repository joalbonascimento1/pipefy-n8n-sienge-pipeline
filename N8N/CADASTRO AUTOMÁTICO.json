      "parameters": {
        "jsCode": "// Acessa os campos dentro do nó \"Request pai\"\nconst fields = $node[\"Request Pai\"].json.data.card.fields;\nconst mapped = {};\n\nfields.forEach(f => {\n    // Cria a chave com o ID do campo e atribui o valor\n    mapped[f.field.id] = f.value;\n});\n\n// Adiciona também o createdAt que estava no mesmo nível\nmapped[\"createdAt\"] = $node[\"Request Pai\"].json.data.card.createdAt;\n\nreturn mapped;"
