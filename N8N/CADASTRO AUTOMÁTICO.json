      "id": "2d29033b-b0ba-44ee-90fb-66ea9ecd118f",
      "name": "CADASTRAR DESPESA",
      "executeOnce": false,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// 1. Acessa o nó \"Request Pai\"\nconst paiData = $('Request Pai').first().json.data.card;\nconst paiFields = paiData.fields;\n\nconst getPaiFieldValue = (id) => {\n    const field = paiFields.find(f => f.field.id === id);\n    return field ? field.value : \"\";\n};\n\n// 🔹 NOVO: regra do faturado_para\nconst faturadoPara = getPaiFieldValue('faturado_para');\nconst isCustomerCharged = faturadoPara === \"Cliente\";\n\n// 🔹 Data\nconst rawDueDate = getPaiFieldValue('data_de_vencimento_definitiva_1');\nlet formattedDueDate = new Date().toISOString().split('T')[0];\n\nif (rawDueDate && rawDueDate.includes('/')) {\n    const partes = rawDueDate.split(' ')[0].split('/');\n    if (partes.length === 3) {\n        formattedDueDate = `${partes[2]}-${partes[1]}-${partes[0]}`;\n    }\n}\n\nconst nomeDocumento = getPaiFieldValue('nome_do_documento');\n\nreturn items.map(item => {\n    const d = item.json;\n\n    // --- CONSOLIDAÇÃO ---\n    const consolidatedMap = {};\n\n    d.rateios.forEach(r => {\n        const key = `${r.id_obra_sienge}_${r.id_cc_sienge}`;\n\n        if (!consolidatedMap[key]) {\n            consolidatedMap[key] = {\n                id_obra: r.id_obra_sienge,\n                nome_obra: r.nome_obra_sienge,\n                nome_cc: r.nome_cc_sienge,\n                id_cc: r.id_cc_sienge,\n                valor: r.valor_rateado\n            };\n        } else {\n            consolidatedMap[key].valor += r.valor_rateado;\n        }\n    });\n\n    const consolidatedArray = Object.values(consolidatedMap);\n\n    // 🔹 NOVO: descrição = concat dos centros de custo (únicos)\n    const centrosUnicos = [...new Set(consolidatedArray.map(r => r.nome_cc))];\n    const descriptionConcatenada = centrosUnicos.join(', ').slice(0, 300);\n\n    const buildings = consolidatedArray.map(r => {\n        const isAdministrativo = r.id_cc === \"0\" || r.nome_cc === \"N/A\" || r.nome_obra === \"ADMINISTRATIVO 26\";\n        \n        return {\n            \"building\": {\n                \"id\": parseInt(r.id_obra),\n                \"name\": r.nome_obra,\n                \"code\": null\n            },\n            \"costEstimateGroup\": isAdministrativo ? null : {\n                \"id\": parseInt(r.id_cc),\n                \"name\": r.nome_cc\n            },\n            \"value\": r.valor,\n            \"increase\": 0,\n            \"discount\": 0,\n            \"grossValue\": r.valor,\n            \"amountPerBuilding\": r.valor,\n            \"isCustomerCharged\": isCustomerCharged // 🔹 AQUI\n        };\n    });\n\n    return {\n        json: {\n            \"data\": {\n                \"category\": { \"id\": parseInt(d.id_categoria) },\n                \"company\": { \"id\": 1492, \"name\": \"FAG ENGENHARIA EIRELI\" },\n                \"partner\": { \"id\": parseInt(d.id_fornecedor), \"name\": d.nome_fornecedor },\n\n                // 🔹 NOVA DESCRIPTION\n                \"description\": descriptionConcatenada,\n\n                \"transactionRecordList\": [\n                    {\n                        \"forecast\": true,\n                        \"sign\": -1,\n                        \"dueDate\": formattedDueDate,\n                        \"transactionRecordBuildings\": buildings,\n                        \"value\": d.valor_total_nf,\n                        \"grossValue\": d.valor_total_nf\n                    }\n                ],\n                \"documentNumber\": nomeDocumento || \" \",\n                \"value\": d.valor_total_nf,\n                \"grossValue\": d.valor_total_nf,\n                \"emissionDate\": new Date().toISOString().split('T')[0],\n                \"partnerId\": parseInt(d.id_fornecedor),\n                \"categoryId\": parseInt(d.id_categoria)\n            }\n        }\n    };\n});"
      },
      "type": "n8n-nodes-base.code",
