    {
      "parameters": {
        "jsCode": "// Acessa todos os itens da entrada\nconst allItems = $input.all();\n\nreturn allItems.map((item, index) => {\n    const relations = item.json.data.card.child_relations;\n    \n    // 1. Localiza a relação de Fornecedor\n    const fornecedorRel = relations.find(r => r.name === \"Fornecedor\");\n    let dadosFornecedor = { id: \"000000\", nome: \"Não encontrado\" };\n\n    if (fornecedorRel && fornecedorRel.cards.length > 0) {\n        const cardFornecedor = fornecedorRel.cards[0];\n        const campoNome = cardFornecedor.fields.find(f => f.field.id === \"nome\");\n        \n        // Criamos o ID único usando o índice da iteração atual do n8n\n        const sufixo = index.toString().padStart(2, '0');\n        \n        dadosFornecedor = {\n            id: `${cardFornecedor.id}_${sufixo}`, \n            nome: campoNome ? campoNome.value : cardFornecedor.title\n        };\n    }\n\n    // 2. Mapeia os Rateios injetando o novo ID Único e a Descrição\n    const rateioRel = relations.find(r => r.name === \"Ratear Centro de Custo\");\n    const listaRateio = rateioRel ? rateioRel.cards.map(card => {\n        const campoCentro = card.fields.find(f => f.field.id.startsWith(\"centro_de_custo\"));\n        const campoValor = card.fields.find(f => f.field.id === \"valor_rateado\");\n        const campoCategoria = card.fields.find(f => f.field.id === \"categoria\");\n        // Captura o campo de Descrição\n        const campoDescricao = card.fields.find(f => f.field.id === \"descri_o\");\n\n        return {\n            fornecedor_nome: dadosFornecedor.nome,\n            fornecedor_card_id: dadosFornecedor.id,\n            rateio_card_id: card.id,\n            centro_de_custo: campoCentro?.report_value || \"N/A\",\n            valor: campoValor?.value || \"0,00\",\n            categoria: campoCategoria?.report_value || \"Sem Categoria\",\n            // Adicionado aqui:\n            descricao: campoDescricao?.value || \"Sem descrição\"\n        };\n    }) : [];\n\n    return {\n        json: {\n            rateios: listaRateio\n        }\n    };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2368,
